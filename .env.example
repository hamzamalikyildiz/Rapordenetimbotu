# Bu dosyayı kopyalayın: cp .env.example .env
# Ardından gerçek değerleri doldurun. .env dosyasını commit ETMEYİN!

# Telegram Bot Token (https://t.me/BotFather adresinden alınır)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (https://aistudio.google.com/apikey adresinden alınır)
GOOGLE_API_KEY=your_google_api_key_here

# Google OAuth credentials.json içeriği (opsiyonel - deployment için)
# CREDENTIALS_JSON={"installed":{...}}
